// src/features/comment/components/CommentListShell.tsx
import Image from 'next/image';

import CommentEmptyState from './CommentEmptyState';

export type CommentShellItem = Readonly<{
  id: number;
  authorName: string;
  text: string;
  timeLabel: string;
  avatarSrc?: string;
}>;

type CommentListShellProps = Readonly<{
  variant?: 'empty' | 'filled';
  comments?: CommentShellItem[];
}>;

const defaultCommentShellItems: CommentShellItem[] = [
  {
    id: 1,
    authorName: 'Alexander',
    text: 'This is the kind of love everyone dreams about ✨',
    timeLabel: '1 Minute Ago',
    avatarSrc: '/assets/avatar/avatar-placeholder.jpg',
  },
  {
    id: 2,
    authorName: 'Alexander',
    text: 'This is the kind of love everyone dreams about ✨',
    timeLabel: '1 Minute Ago',
    avatarSrc: '/assets/avatar/avatar-placeholder.jpg',
  },
  {
    id: 3,
    authorName: 'Alexander',
    text: 'This is the kind of love everyone dreams about ✨',
    timeLabel: '1 Minute Ago',
    avatarSrc: '/assets/avatar/avatar-placeholder.jpg',
  },
  {
    id: 4,
    authorName: 'Alexander',
    text: 'This is the kind of love everyone dreams about ✨',
    timeLabel: '1 Minute Ago',
    avatarSrc: '/assets/avatar/avatar-placeholder.jpg',
  },
];

const CommentListShell = ({
  variant = 'filled',
  comments = defaultCommentShellItems,
}: CommentListShellProps) => {
  if (variant === 'empty') {
    return <CommentEmptyState />;
  }

  return (
    <div className='flex flex-col'>
      {comments.map((comment, index) => (
        <article
          key={comment.id}
          className={`flex gap-3 py-2 ${
            index !== comments.length - 1 ? 'border-b border-border' : ''
          }`}
        >
          <div className='relative h-10 w-10 shrink-0 overflow-hidden rounded-full bg-muted'>
            <Image
              src={comment.avatarSrc ?? '/assets/avatar/avatar-placeholder.jpg'}
              alt={`${comment.authorName} avatar`}
              fill
              sizes='40px'
              className='object-cover'
            />
          </div>

          <div className='min-w-0 flex-1'>
            <div className='flex items-center gap-2'>
              <h4 className='truncate text-sm font-semibold text-foreground'>
                {comment.authorName}
              </h4>

              <span className='text-xs text-muted-foreground'>
                {comment.timeLabel}
              </span>
            </div>

            <p className='mt-0.5 text-sm text-foreground'>{comment.text}</p>
          </div>
        </article>
      ))}
    </div>
  );
};

export default CommentListShell;
